default_platform(:ios)

def required_env!(key)
  value = ENV[key]
  UI.user_error!("Fehlende Umgebungsvariable: #{key}") if value.to_s.empty?
  value
end

def signing_xcargs
  team_id = ENV["BRICKCANVAS_DEVELOPMENT_TEAM"]
  return "" if team_id.to_s.empty?

  "DEVELOPMENT_TEAM=#{team_id}"
end

def release_app_identifiers
  [
    ENV.fetch("BRICKCANVAS_APP_IDENTIFIER", "eu.mpwg.BrickCanvas"),
    ENV.fetch("BRICKCANVAS_MAC_APP_IDENTIFIER", "eu.mpwg.BrickCanvas.mac")
  ]
end

def match_readonly?
  ENV["MATCH_READONLY"] == "1" || ENV["CI"] == "true"
end

def sync_match_signing(api_key:)
  options = {
    api_key: api_key,
    type: "appstore",
    readonly: match_readonly?,
    app_identifier: release_app_identifiers
  }

  keychain_name = ENV["MATCH_KEYCHAIN_NAME"]
  keychain_password = ENV["MATCH_KEYCHAIN_PASSWORD"]

  options[:keychain_name] = keychain_name unless keychain_name.to_s.empty?
  options[:keychain_password] = keychain_password unless keychain_password.to_s.empty?

  match(**options)
end

def app_store_connect_api_key_config
  key_id = required_env!("APP_STORE_CONNECT_API_KEY_ID")
  issuer_id = required_env!("APP_STORE_CONNECT_API_ISSUER_ID")
  key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
  key_filepath = ENV["APP_STORE_CONNECT_API_KEY_FILEPATH"]

  if key_content.to_s.empty? && key_filepath.to_s.empty?
    UI.user_error!(
      "Setze APP_STORE_CONNECT_API_KEY_CONTENT oder APP_STORE_CONNECT_API_KEY_FILEPATH."
    )
  end

  config = {
    key_id: key_id,
    issuer_id: issuer_id,
    duration: 1200,
    in_house: false
  }

  config[:key_content] = key_content unless key_content.to_s.empty?
  config[:key_filepath] = key_filepath unless key_filepath.to_s.empty?
  config
end

platform :ios do
  desc "Erzeugt das Xcode-Projekt aus project.yml"
  lane :generate_project do
    sh("./scripts/generate-xcode-project.sh")
  end

  desc "Synchronisiert Zertifikate und Provisioning Profiles über match"
  lane :sync_signing do
    api_key = app_store_connect_api_key(
      **app_store_connect_api_key_config
    )

    sync_match_signing(api_key: api_key)
  end

  desc "Archiviert die Release-App für iPhone und iPad"
  lane :archive_ios do
    generate_project
    sh(
      "xcodebuild",
      "-project", "BrickCanvas.xcodeproj",
      "-scheme", "BrickCanvas",
      "-configuration", "Release",
      "-destination", "generic/platform=iOS",
      "-archivePath", "build/BrickCanvas-iOS.xcarchive",
      "archive",
      *signing_xcargs.split
    )
  end

  desc "Archiviert die Release-App für Mac Catalyst"
  lane :archive_catalyst do
    generate_project
    sh(
      "xcodebuild",
      "-project", "BrickCanvas.xcodeproj",
      "-scheme", "BrickCanvas",
      "-configuration", "Release",
      "-destination", "generic/platform=macOS,variant=Mac Catalyst",
      "-archivePath", "build/BrickCanvas-MacCatalyst.xcarchive",
      "archive",
      *signing_xcargs.split
    )
  end

  desc "Baut ein App-Store-Artefakt und lädt es nach TestFlight hoch"
  lane :beta do
    generate_project

    api_key = app_store_connect_api_key(
      **app_store_connect_api_key_config
    )

    sync_match_signing(api_key: api_key)

    build_app(
      project: "BrickCanvas.xcodeproj",
      scheme: "BrickCanvas",
      configuration: "Release",
      clean: true,
      destination: "generic/platform=iOS",
      export_method: "app-store",
      output_directory: "build",
      output_name: "BrickCanvas",
      xcargs: signing_xcargs
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["BRICKCANVAS_BETA_CHANGELOG"],
      beta_app_description: ENV["BRICKCANVAS_BETA_DESCRIPTION"],
      beta_app_feedback_email: ENV["BRICKCANVAS_BETA_FEEDBACK_EMAIL"],
      demo_account_required: false
    )
  end
end
